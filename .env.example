# ============================================================
# Jeannot Tsirenge — Architecture Portfolio
# Environment configuration template
#
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Django core — REQUIRED in all environments
# ------------------------------------------------------------

# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production — never leave True on a live site
DEBUG=True

# Comma-separated list of allowed hostnames
# Local dev:       localhost,127.0.0.1
# Production:      yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------
# Settings module — controls which settings file Django loads
# ------------------------------------------------------------
# Local dev (default — set automatically by manage.py):
#   DJANGO_SETTINGS_MODULE=config.settings.dev
#
# Production — MUST be set explicitly in your hosting environment:
#   DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Leave unset to use SQLite (local dev only).
# Set for any shared or production environment.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=postgres://user:password@localhost:5432/jeannote

# ------------------------------------------------------------
# Email — REQUIRED in production for contact form notifications
# ------------------------------------------------------------
# MUST be set to an SMTP backend before going live.
# Without it, contact form submissions are saved to the database
# but the architect receives NO email notification.
#
# Console backend (local dev — prints to terminal, no mail sent):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# SMTP backend (production):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-smtp-username
# EMAIL_HOST_PASSWORD=your-smtp-password
#
# Address that appears in the "From" field of outgoing emails.
# Use a real deliverable address; many SMTP services require it to
# match the authenticated user above.
# DEFAULT_FROM_EMAIL=Jeannot Tsirenge <contact@jeannot-tsirenge.com>
#
# Address that receives contact form notifications.
CONTACT_EMAIL=contact@jeannot-tsirenge.com

# ------------------------------------------------------------
# Security — REQUIRED in production
# ------------------------------------------------------------
# Comma-separated list of trusted origins for CSRF protection.
# Must include the scheme (https). Required when behind a reverse proxy.
# Example: https://yourdomain.com,https://www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ------------------------------------------------------------
# Media file storage — REQUIRED for real uploaded content
# ------------------------------------------------------------
# By default, media files are stored on the local filesystem (media/).
# This is NOT suitable for production on ephemeral platforms (Heroku,
# Render, Fly.io) — files are lost on every deploy or restart.
#
# To use S3-compatible cloud storage (recommended):
#   1. pip install django-storages[s3] boto3
#   2. Uncomment and fill in the vars below
#   3. See docs/media-storage.md for full setup instructions
#
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=af-south-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_CUSTOM_DOMAIN=your-bucket.s3.amazonaws.com
# DEFAULT_FILE_STORAGE=storages.backends.s3boto3.S3Boto3Storage

